# Database (Railway sets DATABASE_URL automatically for PostgreSQL add-on)
DATABASE_URL=sqlite:///./jetleads.db

# Redis (optional — for background job queues)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production

# Frontend URL (used for CORS — set to your Railway frontend domain)
FRONTEND_URL=https://your-frontend.up.railway.app

# Email — Resend (primary)
# TODO: change RESEND_FROM_EMAIL to noreply@jetleads.io after verifying jetleads.io on resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jetleads.io

# Email — SendGrid (fallback, optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@jetleads.io

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Meta Lead Ads
META_APP_SECRET=

# Anthropic API
ANTHROPIC_API_KEY=

# App
DEBUG=false
